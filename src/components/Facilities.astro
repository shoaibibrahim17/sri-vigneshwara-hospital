---
// Facilities / Why Choose Us — compact two-column icon list on a single
// tinted band. No boxes, no shadows; dividers carry the structure.

interface Facility {
	title: string;
	desc: string;
	accent: 'teal' | 'rose';
	icon: string;
}

const facilities: Facility[] = [
	{
		title: 'Experienced Care',
		desc: 'Specialists across all four departments.',
		accent: 'teal',
		icon: `<path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2Z"/><path d="m9 12 2 2 4-4"/>`,
	},
	{
		title: 'Patient-Focused',
		desc: 'Clear explanations and honest advice.',
		accent: 'rose',
		icon: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>`,
	},
	{
		title: 'Clean Facilities',
		desc: 'Hygienic and well-kept, every day.',
		accent: 'teal',
		icon: `<path d="m3 21 9-9"/><path d="M12.2 6.2 11 5a2.83 2.83 0 0 0-4 0l-2 2a2.83 2.83 0 0 0 0 4l1.2 1.2"/><path d="m21 3-9 9"/><path d="M17.8 11.8 19 13a2.83 2.83 0 0 1 0 4l-2 2a2.83 2.83 0 0 1-4 0l-1.2-1.2"/>`,
	},
	{
		title: 'Accessible Location',
		desc: 'Central Vidya Nagar, easy to reach.',
		accent: 'rose',
		icon: `<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>`,
	},
	{
		title: 'Modern Treatment',
		desc: 'Current practices, applied thoughtfully.',
		accent: 'teal',
		icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
	},
];
---

<section id="facilities" class="bg-off-white" aria-labelledby="facilities-heading">
	<div class="container-site section-pad lg:px-12">
		<div class="mb-7 lg:mb-10">
			<p class="label-caps text-text-muted">Why Choose Us</p>
			<h2 id="facilities-heading" class="mt-2 text-text-dark">Care You Can Rely On</h2>
		</div>

		<ul
			class="grid grid-cols-2 gap-x-5 gap-y-6 lg:grid-cols-5 lg:gap-x-8"
		>
			{
				facilities.map((f) => (
					<li class="flex flex-col">
						<span
							class:list={[
								'mb-2.5 inline-flex',
								f.accent === 'teal' ? 'text-primary-dark' : 'text-maternity-deep',
							]}
						>
							<svg
								aria-hidden="true"
								class="size-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								set:html={f.icon}
							/>
						</span>
						<h3 class="text-[15px] font-semibold text-text-dark">{f.title}</h3>
						<p class="mt-0.5 text-[13px] leading-snug text-text-muted">{f.desc}</p>
					</li>
				))
			}
		</ul>
	</div>
</section>
