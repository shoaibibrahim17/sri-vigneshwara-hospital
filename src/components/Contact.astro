---
// Contact — compact mobile stack: header → info block → map preview → form.
// Form is contained within the section (no cross-section overlap card).
// Dark teal ground; form on a white panel. Formspree placeholder ID.

const mapSrc =
	'https://www.google.com/maps?q=' +
	encodeURIComponent('Sri Vigneshwara Hospital, Vidya Nagar, Adilabad') +
	'&output=embed';

const departments = ['Orthopaedics', 'Maternity', 'Paediatrics', 'Gynaecology', 'General Enquiry'];

const inputClass =
	'w-full rounded-[12px] border border-black/[0.06] bg-off-white px-3.5 py-3 font-sans text-[15px] text-text-body placeholder:text-text-muted/65 focus:border-primary-dark/40 focus:bg-white focus:ring-2 focus:ring-primary-dark/15 focus:outline-none';
---

<section id="contact" class="bg-primary-dark" aria-labelledby="contact-heading">
	<div class="container-site section-pad lg:px-12">
		<div class="lg:grid lg:grid-cols-[2fr_3fr] lg:gap-16">
			<!-- Info -->
			<div>
				<p class="label-caps text-white/60">Contact</p>
				<h2 id="contact-heading" class="mt-2 text-text-light">
					Visit Us
				</h2>

				<a
					href="tel:9849287515"
					class="mt-4 inline-block text-[26px] leading-none font-bold text-cta [font-variant-numeric:tabular-nums] transition-colors duration-150 hover:text-cta-hover lg:text-[36px]"
				>
					98492 87515
				</a>

				<div class="mt-4 space-y-2 text-sm leading-relaxed text-white/85">
					<p>Raviteja Hotel Lane, Vidya Nagar, Adilabad, Telangana 504001</p>
					<p>Mon &ndash; Sun: 11:00 AM &ndash; 5:00 PM</p>
				</div>

				<!-- Map preview — compact on mobile -->
				<iframe
					src={mapSrc}
					title="Map showing the location of Sri Vigneshwara Hospital in Vidya Nagar, Adilabad"
					class="mt-5 h-[180px] w-full rounded-xl border-2 border-maternity/60 lg:mt-6 lg:h-[300px]"
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					allowfullscreen
				>
				</iframe>
			</div>

			<!-- Enquiry form -->
			<form
				action="https://formspree.io/f/YOUR_FORM_ID"
				method="POST"
				class="mt-8 rounded-[16px] border border-black/[0.06] bg-white p-5 lg:mt-0 lg:p-8"
			>
				<h3 class="text-lg font-semibold text-text-dark">Send an Enquiry</h3>

				<div class="mt-4 space-y-3.5">
					<div>
						<label for="contact-name" class="mb-1 block label-caps text-text-muted">
							Full Name
						</label>
						<input
							id="contact-name"
							name="name"
							type="text"
							placeholder="Your name"
							required
							class={inputClass}
						/>
					</div>
					<div>
						<label for="contact-phone" class="mb-1 block label-caps text-text-muted">
							Phone Number
						</label>
						<input
							id="contact-phone"
							name="phone"
							type="tel"
							placeholder="9849287515"
							required
							class={inputClass}
						/>
					</div>
					<div>
						<label for="contact-department" class="mb-1 block label-caps text-text-muted">
							Select Department
						</label>
						<select id="contact-department" name="department" class={inputClass}>
							{departments.map((d) => <option value={d}>{d}</option>)}
						</select>
					</div>
					<div>
						<label for="contact-message" class="mb-1 block label-caps text-text-muted">
							Your Message
						</label>
						<textarea
							id="contact-message"
							name="message"
							rows="3"
							placeholder="How can we help you?"
							class={inputClass}></textarea>
					</div>
				</div>

				<p class="mt-3 text-xs leading-relaxed text-text-muted">
					By submitting, you agree that the hospital may contact you on the phone number
					provided regarding your enquiry.
				</p>

				<button
					type="submit"
					class="mt-4 inline-flex min-h-[48px] w-full items-center justify-center rounded-[12px] bg-primary-dark px-6 py-3 font-sans text-[15px] font-semibold text-white transition-colors duration-150 hover:bg-primary-deep focus-visible:outline-white"
				>
					Send Enquiry
				</button>
			</form>
		</div>
	</div>
</section>
