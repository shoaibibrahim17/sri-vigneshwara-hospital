---
// Journey — split storytelling section: Orthopaedic timeline (dark teal, left)
// and Maternity timeline (blush, right), joined by a rose S-curve divider.
// Icons are inlined Lucide SVGs (no React runtime).

interface Step {
	title: string;
	description: string;
	icon: string; // inner SVG markup from Lucide
}

const orthoSteps: Step[] = [
	{
		title: 'Consultation',
		description: 'Meet our specialists and share your history and concerns.',
		icon: `<rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/>`,
	},
	{
		title: 'Diagnosis',
		description: 'X-ray and clinical assessment to find the exact cause.',
		icon: `<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><path d="M7 12h10"/>`,
	},
	{
		title: 'Treatment',
		description: 'Surgery or conservative care, planned around you.',
		icon: `<path d="m8 14-6 6h9v-3"/><path d="M18.37 3.63 8 14l3 3L21.37 6.63a2.12 2.12 0 1 0-3-3Z"/>`,
	},
	{
		title: 'Recovery',
		description: 'Guided rehabilitation until you are back on your feet.',
		icon: `<circle cx="12" cy="5" r="1"/><path d="m9 20 3-6 3 6"/><path d="m6 8 6 2 6-2"/><path d="M12 10v4"/>`,
	},
];

const maternitySteps: Step[] = [
	{
		title: 'Prenatal',
		description: 'Regular checkups and counselling through every trimester.',
		icon: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>`,
	},
	{
		title: 'Delivery',
		description: 'Safe normal and caesarean deliveries in caring hands.',
		icon: `<path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/>`,
	},
	{
		title: 'Newborn Care',
		description: 'Paediatric attention and vaccinations from day one.',
		icon: `<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>`,
	},
	{
		title: 'Recovery',
		description: 'Postnatal support for a healthy mother and baby.',
		icon: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>`,
	},
];
---

<section id="journey" aria-label="Patient journeys at our hospital">
	<div class="container-site section-pad lg:px-12">
		<div class="relative grid grid-cols-1 overflow-hidden rounded-2xl sm:grid-cols-2">
			<!-- LEFT — Orthopaedic journey (dark teal) -->
			<div class="relative bg-primary-dark p-6 py-12 sm:p-8 lg:p-12">
				<!-- Corner art: knee joint line drawing -->
				<svg
					aria-hidden="true"
					class="pointer-events-none absolute -right-6 -bottom-6 h-48 w-auto text-white opacity-[0.06]"
					viewBox="0 0 120 160"
					fill="none"
					stroke="currentColor"
					stroke-width="3"
					stroke-linecap="round"
				>
					<path d="M48 8 C 44 40, 52 60, 50 74" />
					<path d="M72 8 C 76 40, 68 60, 70 74" />
					<circle cx="50" cy="82" r="10" />
					<circle cx="70" cy="82" r="10" />
					<path d="M52 92 C 48 118, 54 140, 50 154" />
					<path d="M68 92 C 72 118, 66 140, 70 154" />
				</svg>
				<p class="label-caps text-white/60">Orthopaedic Care</p>
				<h2 class="mt-3 text-text-light">
					Your Journey To Better Mobility
				</h2>
				<p class="mt-3 text-base leading-relaxed text-white/70">
					From diagnosis to recovery, we walk with you every step.
				</p>

				<ol class="mt-8">
					{
						orthoSteps.map((step, i) => (
							<li class="flex gap-4">
								<div class="flex flex-col items-center">
									<div class="flex size-10 shrink-0 items-center justify-center rounded-full bg-primary-mid">
										<svg
											aria-hidden="true"
											class="size-5 text-white"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											set:html={step.icon}
										/>
									</div>
									{i < orthoSteps.length - 1 && (
										<div class="min-h-6 w-0 flex-1 border-l-2 border-dashed border-white/20" />
									)}
								</div>
								<div class:list={[i < orthoSteps.length - 1 && 'pb-6']}>
									<h3 class="text-base font-semibold text-text-light">{step.title}</h3>
									<p class="mt-1 text-sm leading-normal text-white/70">{step.description}</p>
								</div>
							</li>
						))
					}
				</ol>
			</div>

			<!-- Mobile separator: both journeys, one roof -->
			<div aria-hidden="true" class="h-0.5 w-full bg-maternity sm:hidden"></div>

			<!-- RIGHT — Maternity journey (blush) -->
			<div class="relative bg-maternity-soft p-6 py-12 sm:p-8 lg:p-12">
				<!-- Corner art: mother cradling baby, single-line drawing -->
				<svg
					aria-hidden="true"
					class="pointer-events-none absolute -right-4 -bottom-4 h-44 w-auto text-maternity opacity-20"
					viewBox="0 0 140 160"
					fill="none"
					stroke="currentColor"
					stroke-width="3"
					stroke-linecap="round"
				>
					<circle cx="82" cy="28" r="16" />
					<path d="M62 52 C 44 62, 36 86, 40 112 C 43 132, 56 148, 78 154" />
					<path d="M100 52 C 114 64, 120 84, 114 104" />
					<path d="M52 96 C 62 112, 84 118, 102 108" />
					<circle cx="66" cy="98" r="10" />
				</svg>
				<p class="label-caps text-maternity">Maternity Care</p>
				<h2 class="mt-3 text-text-dark">
					Your Journey To Motherhood
				</h2>
				<p class="mt-3 text-base leading-relaxed text-text-muted">
					From pregnancy to postnatal, we nurture you and your baby.
				</p>

				<ol class="mt-8">
					{
						maternitySteps.map((step, i) => (
							<li class="flex gap-4">
								<div class="flex flex-col items-center">
									<div class="flex size-10 shrink-0 items-center justify-center rounded-full border-2 border-maternity bg-maternity-soft">
										<svg
											aria-hidden="true"
											class="size-5 text-maternity"
											viewBox="0 0 24 24"
											fill="none"
											stroke="currentColor"
											stroke-width="2"
											stroke-linecap="round"
											stroke-linejoin="round"
											set:html={step.icon}
										/>
									</div>
									{i < maternitySteps.length - 1 && (
										<div class="min-h-6 w-0 flex-1 border-l-2 border-dashed border-maternity/40" />
									)}
								</div>
								<div class:list={[i < maternitySteps.length - 1 && 'pb-6']}>
									<h3 class="text-base font-semibold text-text-dark">{step.title}</h3>
									<p class="mt-1 text-sm leading-normal text-text-muted">{step.description}</p>
								</div>
							</li>
						))
					}
				</ol>
			</div>

			<!-- Desktop divider: soft S-curve at the seam, rose 30% -->
			<svg
				aria-hidden="true"
				class="pointer-events-none absolute left-1/2 top-0 hidden h-full w-8 -translate-x-1/2 text-maternity opacity-30 sm:block"
				viewBox="0 0 32 480"
				preserveAspectRatio="none"
				fill="none"
				stroke="currentColor"
				stroke-width="3"
				stroke-linecap="round"
			>
				<path d="M16 0 C 28 60, 4 120, 16 180 C 28 240, 4 300, 16 360 C 28 420, 10 450, 16 480" />
			</svg>
		</div>
	</div>
</section>
