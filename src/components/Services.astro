---
// Departments — compact 2×2 navigation grid (4-up on desktop).
// Tiles are navigation, not content containers: icon, title, one line,
// arrow. Detailed service lists live in the dedicated feature sections.
// Alternating soft teal / blush backgrounds with the shared premium card treatment.

interface Department {
	title: string;
	line: string;
	accent: 'teal' | 'rose';
	image: string;
	alt: string;
	imageClass?: string;
	href: string;
}

const departments: Department[] = [
	{
		title: 'Orthopaedics',
		line: 'Fracture, joint & spine care',
		accent: 'teal',
		image: '/images/department-orthopaedics.webp',
		alt: 'Orthopaedic knee and spine care illustration',
		href: '#orthopaedics',
	},
	{
		title: 'Maternity',
		line: 'Pregnancy to postnatal care',
		accent: 'rose',
		image: '/images/department-maternity.webp',
		alt: 'Mother and newborn maternity care illustration',
		imageClass: 'scale-90',
		href: '#maternity',
	},
	{
		title: 'Paediatrics',
		line: 'Newborn & child health',
		accent: 'teal',
		image: '/images/department-paediatrics.webp',
		alt: 'Paediatric child healthcare illustration',
		href: '#doctors',
	},
	{
		title: 'Gynaecology',
		line: "Women's health & checkups",
		accent: 'rose',
		image: '/images/department-gynaecology.webp',
		alt: 'Gynaecology and women’s health illustration',
		href: '#doctors',
	},
];
---

<section id="departments" class="bg-white" aria-labelledby="services-heading">
	<div class="container-site section-pad lg:px-12">
		<div class="mb-6 lg:mb-12">
			<p class="label-caps text-text-muted">Our Departments</p>
			<h2 id="services-heading" class="mt-2 text-text-dark">
				Comprehensive Care for Your Family
			</h2>
		</div>

		<ul class="grid grid-cols-2 gap-3 lg:grid-cols-4 lg:gap-5">
			{
				departments.map((d) => (
					<li>
						<a
							href={d.href}
							class:list={[
								'group flex h-full min-h-[156px] flex-col rounded-[16px] border border-black/[0.06] p-3 transition-[background-color,box-shadow,transform] duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] sm:p-4 lg:min-h-[184px]',
								d.accent === 'teal' ? 'bg-ice hover:bg-primary-mid/15' : 'bg-maternity-soft hover:bg-maternity/20',
							]}
						>
							<img
								src={d.image}
								alt={d.alt}
								width="320"
								height="320"
								loading="lazy"
								decoding="async"
								class:list={[
									'size-12 object-contain object-center lg:size-[72px]',
									d.imageClass,
								]}
							/>
							<h3 class="mt-1.5 text-[14px] font-semibold text-text-dark sm:text-base">{d.title}</h3>
							<p class="mt-0.5 text-[13px] leading-snug text-text-muted">{d.line}</p>
							<span
								class:list={[
									'mt-auto inline-flex items-center gap-1 pt-2 text-xs font-semibold',
									d.accent === 'teal' ? 'text-primary-mid' : 'text-maternity-deep',
								]}
							>
								<span class="sr-only">{d.title}:</span>
								Explore
								<svg
									aria-hidden="true"
									class="size-3.5 transition-transform duration-150 group-hover:translate-x-0.5"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M5 12h14M12 5l7 7-7 7" />
								</svg>
							</span>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>
