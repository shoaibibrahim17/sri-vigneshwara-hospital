---
// Departments — compact 2×2 navigation grid (4-up on desktop).
// Tiles are navigation, not content containers: icon, title, one line,
// arrow. Detailed service lists live in the dedicated feature sections.
// Alternating soft teal / blush tinted backgrounds; no borders or shadows.

interface Department {
	title: string;
	line: string;
	accent: 'teal' | 'rose';
	icon: string; // inner SVG markup from Lucide
	href: string;
}

const departments: Department[] = [
	{
		title: 'Orthopaedics',
		line: 'Fracture, joint & spine care',
		accent: 'teal',
		icon: `<path d="M17 10c.7-.7 1.69 0 2.5 0a2.5 2.5 0 1 0 0-5 .5.5 0 0 1-.5-.5 2.5 2.5 0 1 0-5 0c0 .81.7 1.8 0 2.5l-7 7c-.7.7-1.69 0-2.5 0a2.5 2.5 0 0 0 0 5c.28 0 .5.22.5.5a2.5 2.5 0 1 0 5 0c0-.81-.7-1.8 0-2.5Z"/>`,
		href: '#orthopaedics',
	},
	{
		title: 'Maternity',
		line: 'Pregnancy to postnatal care',
		accent: 'rose',
		icon: `<path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/>`,
		href: '#maternity',
	},
	{
		title: 'Paediatrics',
		line: 'Newborn & child health',
		accent: 'teal',
		icon: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/>`,
		href: '#doctors',
	},
	{
		title: 'Gynaecology',
		line: "Women's health & checkups",
		accent: 'rose',
		icon: `<path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/>`,
		href: '#doctors',
	},
];
---

<section id="departments" class="bg-white" aria-labelledby="services-heading">
	<div class="container-site section-pad lg:px-12">
		<div class="mb-8 lg:mb-12">
			<p class="label-caps text-text-muted">Our Departments</p>
			<h2 id="services-heading" class="mt-2 text-text-dark">
				Comprehensive Care for Your Family
			</h2>
		</div>

		<ul class="grid grid-cols-2 gap-3 lg:grid-cols-4 lg:gap-5">
			{
				departments.map((d) => (
					<li>
						<a
							href={d.href}
							class:list={[
								'group flex h-full min-h-[150px] flex-col rounded-xl p-4 transition-colors duration-150 sm:p-5',
								d.accent === 'teal' ? 'bg-ice hover:bg-primary-mid/15' : 'bg-maternity-soft hover:bg-maternity/20',
							]}
						>
							<svg
								aria-hidden="true"
								class:list={[
									'size-6',
									d.accent === 'teal' ? 'text-primary-dark' : 'text-maternity-deep',
								]}
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								set:html={d.icon}
							/>
							<h3 class="mt-3 text-[15px] font-semibold text-text-dark sm:text-base">{d.title}</h3>
							<p class="mt-0.5 text-[13px] leading-snug text-text-muted">{d.line}</p>
							<span
								class:list={[
									'mt-auto inline-flex items-center gap-1 pt-3 text-xs font-semibold',
									d.accent === 'teal' ? 'text-primary-mid' : 'text-maternity-deep',
								]}
							>
								<span class="sr-only">{d.title}:</span>
								Explore
								<svg
									aria-hidden="true"
									class="size-3.5 transition-transform duration-150 group-hover:translate-x-0.5"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
								>
									<path d="M5 12h14M12 5l7 7-7 7" />
								</svg>
							</span>
						</a>
					</li>
				))
			}
		</ul>
	</div>
</section>
