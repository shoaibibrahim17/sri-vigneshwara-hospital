---
// FAQ — Anore-inspired "Frequently Asked" block. Native <details> accordion:
// no JS, keyboard-accessible out of the box.

interface Faq {
	q: string;
	a: string;
}

const faqs: Faq[] = [
	{
		q: 'What are the hospital timings?',
		// UNVERIFIED: emergency availability pending client confirmation
		a: 'The hospital is open Monday to Sunday, 11:00 AM to 5:00 PM. Dr. Ravikanth Rao is available Monday to Saturday, 9:30 AM to 6:30 PM. For emergencies, please call us directly.',
	},
	{
		q: 'Do I need an appointment for a consultation?',
		a: 'Walk-ins are welcome, but we recommend calling 98492 87515 ahead so we can reduce your waiting time. You can also send an enquiry through the form below.',
	},
	{
		q: 'Which delivery options are available?',
		a: 'We support both normal and caesarean deliveries, with prenatal counselling through every trimester and high-risk pregnancy management under our OBGYN specialist.',
	},
	{
		q: 'Are vaccinations for children available?',
		a: 'Yes. Routine immunisation and vaccination for newborns, infants and children are provided by our paediatrician, Dr. Ravikanth Rao.',
	},
	{
		q: 'Where is the hospital located?',
		a: 'We are at Raviteja Hotel Lane, Vidya Nagar, Adilabad, Telangana 504001 — near Raviteja Hotel. Use the map in the Contact section for directions.',
	},
];
---

<section id="faq" class="bg-white" aria-labelledby="faq-heading">
	<div class="container-site section-pad lg:px-12">
		<div class="grid grid-cols-1 gap-10 lg:grid-cols-[2fr_3fr] lg:gap-16">
			<!-- Left: header -->
			<div>
				<p class="label-caps text-text-muted">Common Questions</p>
				<h2 id="faq-heading" class="mt-3 text-text-dark">Frequently Asked Questions</h2>
				<p class="mt-4 max-w-[400px] text-base leading-relaxed text-text-muted">
					Answers to what patients ask us most. For anything else, call us directly &mdash; we are
					happy to help.
				</p>
				<a
					href="tel:9849287515"
					class="mt-6 inline-flex min-h-[44px] items-center gap-2 text-base font-semibold text-primary-mid transition-colors duration-150 hover:text-primary-dark"
				>
					<svg
						aria-hidden="true"
						class="size-4"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
					</svg>
					Call 98492 87515
				</a>
			</div>

			<!-- Right: accordion -->
			<div class="space-y-2.5">
				{
					faqs.map((faq) => (
						<details name="hospital-faq" class="faq-item group overflow-hidden rounded-[16px] border border-black/[0.06] bg-off-white transition-shadow duration-200 hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)]">
							<summary class="flex min-h-[54px] cursor-pointer list-none items-center justify-between gap-4 px-4 py-3.5 text-[15px] font-semibold text-text-dark transition-colors duration-150 hover:bg-ice/70 focus-visible:bg-ice/70 sm:text-base [&::-webkit-details-marker]:hidden">
								{faq.q}
								<svg
									aria-hidden="true"
									class="size-7 shrink-0 rounded-full bg-white p-1.5 text-primary-mid ring-1 ring-black/[0.06] transition-transform duration-300 ease-out group-open:rotate-45"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
								>
									<path d="M12 5v14M5 12h14" />
								</svg>
							</summary>
							<div class="faq-answer"><div><p class="px-4 pr-12 pb-4 text-sm leading-relaxed text-text-muted">{faq.a}</p></div></div>
						</details>
					))
				}
			</div>
		</div>
	</div>
</section>
