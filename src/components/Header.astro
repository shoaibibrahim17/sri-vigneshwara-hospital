---
// Header — sticky white nav: two-line text logo (never truncated), desktop
// links, compact call CTA, hamburger below md:. Toggle behaviour lives in
// Layout.astro's script via [data-menu-toggle] / [data-mobile-menu].

const navLinks = [
	{ label: 'Home', href: '#home' },
	{ label: 'Departments', href: '#departments' },
	{ label: 'Doctors', href: '#doctors' },
	{ label: 'Facilities', href: '#facilities' },
	{ label: 'Contact', href: '#contact' },
];
---

<header class="sticky top-0 z-50 border-b border-border-light bg-white">
	<div class="container-site flex h-16 items-center justify-between gap-3 lg:h-[72px] lg:px-12">
		<!-- Text logo — sized to fit 360px without ellipsis -->
		<a href="#home" class="flex min-w-0 flex-col leading-tight">
			<span class="font-heading text-[15px] font-bold tracking-wide text-primary-dark sm:text-base lg:text-lg">
				SRI VIGNESHWARA
			</span>
			<span class="text-[8.5px] tracking-[0.06em] text-text-muted uppercase sm:text-[10px] lg:text-[11px]">
				Orthopaedic &amp; Maternity Hospital
			</span>
		</a>

		<!-- Desktop nav -->
		<nav aria-label="Main navigation" class="hidden md:block">
			<ul class="flex items-center gap-6 lg:gap-8">
				{
					navLinks.map((link) => (
						<li>
							<a
								href={link.href}
								class="text-[15px] font-medium text-text-body transition-colors duration-150 hover:text-primary-mid"
							>
								{link.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="flex items-center gap-1.5">
			<!-- Appointment CTA (desktop only; lives in the drawer on mobile) -->
			<a
				href="#contact"
				class="hidden min-h-[44px] items-center justify-center rounded-[10px] border border-primary-dark px-4 py-2 text-sm font-semibold text-primary-dark transition-colors duration-150 hover:bg-primary-dark hover:text-white lg:inline-flex"
			>
				Book Appointment
			</a>
			<!-- Compact click-to-call -->
			<a
				href="tel:9849287515"
				class="inline-flex min-h-[44px] items-center justify-center gap-1.5 rounded-[10px] bg-cta px-3.5 py-2 text-sm font-semibold text-text-dark transition-colors duration-150 hover:bg-cta-hover lg:px-5 lg:text-base"
			>
				<svg
					aria-hidden="true"
					class="size-4"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
				</svg>
				<span class="hidden sm:inline">98492 87515</span>
				<span class="sm:hidden">Call</span>
			</a>

			<!-- Hamburger (mobile only) -->
			<button
				type="button"
				data-menu-toggle
				aria-expanded="false"
				aria-controls="mobile-menu"
				aria-label="Open menu"
				class="inline-flex size-11 items-center justify-center rounded-[10px] text-text-dark transition-colors duration-150 hover:bg-off-white md:hidden"
			>
				<svg
					aria-hidden="true"
					class="size-6"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
				>
					<path d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
	</div>

	<!-- Mobile drawer: simple, full-width, editorial -->
	<nav
		id="mobile-menu"
		data-mobile-menu
		aria-label="Mobile navigation"
		class="hidden border-t border-border-light bg-white md:hidden"
	>
		<ul class="container-site divide-y divide-border-light py-1">
			{
				navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="block min-h-[44px] py-3.5 text-base font-medium text-text-body transition-colors duration-150 hover:text-primary-mid"
						>
							{link.label}
						</a>
					</li>
				))
			}
			<li class="py-3.5">
				<a
					href="#contact"
					class="inline-flex min-h-[44px] w-full items-center justify-center rounded-[10px] border border-primary-dark px-4 py-2.5 text-sm font-semibold text-primary-dark transition-colors duration-150 hover:bg-primary-dark hover:text-white"
				>
					Book Appointment
				</a>
			</li>
		</ul>
	</nav>
</header>
