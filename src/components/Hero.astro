---
// Mobile-first art-directed hero using the two approved hospital visual assets.
const directionsUrl =
	'https://www.google.com/maps/dir/?api=1&destination=' +
	encodeURIComponent('Sri Vigneshwara Hospital, Vidya Nagar, Adilabad');
---

<section id="home" class="hero-poster relative overflow-hidden" aria-labelledby="hero-heading">
	<div class="container-site relative min-h-[650px] pt-7 pb-8 sm:min-h-[690px] sm:pt-10 lg:min-h-[660px] lg:px-12 lg:pt-20 lg:pb-16">
		<div class="hero-copy-enter relative z-20 max-w-[610px] lg:max-w-[570px]">
			<p class="text-[10px] leading-snug font-semibold tracking-[0.12em] text-primary-mid uppercase sm:text-[11px]">
				Sri Vigneshwara Orthopaedic &amp; Maternity Hospital
			</p>

			<h1 id="hero-heading" class="mt-3 max-w-[360px] font-sans text-[clamp(2.5rem,11vw,2.875rem)] leading-[0.96] font-bold tracking-[-0.035em] text-balance text-text-dark sm:max-w-[430px] lg:max-w-[620px] lg:text-[clamp(3.8rem,5.4vw,4.8rem)] lg:leading-[0.95]">
				Trusted Orthopaedic &amp; Maternity Care in Adilabad
			</h1>

			<p class="mt-4 max-w-[43ch] text-[15px] leading-[1.58] text-text-muted sm:text-base lg:mt-5 lg:text-[17px]">
				Specialist care for mobility, pregnancy, women&rsquo;s health and children &mdash; delivered with compassion under one roof.
			</p>
		</div>

		<div class="hero-collage relative z-10 mt-3 h-[310px] w-full sm:mt-5 sm:h-[340px] lg:absolute lg:top-10 lg:right-0 lg:mt-0 lg:h-[580px] lg:w-[62%]">
			<div class="absolute top-0 right-5 h-[275px] w-[205px] overflow-hidden rounded-[48%_48%_42%_42%] sm:right-16 sm:h-[310px] sm:w-[235px] lg:top-0 lg:right-[120px] lg:h-[550px] lg:w-[410px]">
				<img src="/images/hero-orthopaedic-visual.webp" alt="Orthopaedic knee and spine care illustration" width="800" height="1067" fetchpriority="high" class="h-full w-full object-cover object-[center_30%] mix-blend-multiply" />
			</div>

			<div class="absolute right-0 bottom-1 z-20 h-[205px] w-[155px] overflow-hidden rounded-t-full rounded-b-[42%] bg-[#FBF3EE]/75 shadow-[0_14px_34px_rgba(15,76,75,0.08)] ring-1 ring-white/70 sm:right-5 sm:h-[230px] sm:w-[175px] lg:right-0 lg:bottom-12 lg:h-[380px] lg:w-[285px]">
				<img src="/images/hero-maternity-visual.webp" alt="Mother and newborn maternity care illustration" width="800" height="1067" loading="eager" decoding="async" class="h-full w-full object-cover object-[center_39%] mix-blend-multiply" />
			</div>

			<div class="absolute top-7 left-1 z-30 inline-flex max-w-[98px] items-center gap-1.5 rounded-[9px] border border-primary-dark/8 bg-white/90 px-2.5 py-2 text-[10px] leading-tight font-semibold text-primary-dark shadow-[0_8px_24px_rgba(15,76,75,0.06)] sm:left-8 lg:top-28 lg:left-4 lg:text-[11px]">
				<svg aria-hidden="true" class="size-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 10c.7-.7 1.69 0 2.5 0a2.5 2.5 0 1 0 0-5 .5.5 0 0 1-.5-.5 2.5 2.5 0 1 0-5 0c0 .81.7 1.8 0 2.5l-7 7c-.7.7-1.69 0-2.5 0a2.5 2.5 0 0 0 0 5c.28 0 .5.22.5.5a2.5 2.5 0 1 0 5 0c0-.81-.7-1.8 0-2.5Z" /></svg>
				Orthopaedic Care
			</div>

			<div class="absolute bottom-[62px] left-4 z-30 inline-flex max-w-[92px] items-center gap-1.5 rounded-[9px] border border-maternity/20 bg-white/92 px-2.5 py-2 text-[10px] leading-tight font-semibold text-maternity-deep shadow-[0_8px_24px_rgba(158,79,99,0.06)] sm:left-12 lg:bottom-32 lg:left-20 lg:text-[11px]">
				<svg aria-hidden="true" class="size-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" /></svg>
				Maternity Care
			</div>
		</div>

		<div class="relative z-30 -mt-9 grid max-w-[350px] grid-cols-[0.94fr_1.06fr] gap-2 sm:-mt-8 sm:flex sm:max-w-none sm:flex-wrap lg:absolute lg:bottom-[82px] lg:left-12 lg:mt-0">
			<a href="tel:9849287515" class="inline-flex min-h-[46px] items-center justify-center gap-1.5 rounded-[10px] bg-cta px-3 text-[13px] font-semibold text-text-dark transition-colors duration-150 hover:bg-cta-hover sm:w-[166px] sm:text-sm">
				<svg aria-hidden="true" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.36 1.79.7 2.63a2 2 0 0 1-.45 2.11L8.09 9.73a16 16 0 0 0 6.18 6.18l1.27-1.27a2 2 0 0 1 2.11-.45c.84.34 1.73.58 2.63.7A2 2 0 0 1 22 16.92z" /></svg>
				Call Hospital
			</a>
			<a href="#contact" class="inline-flex min-h-[46px] items-center justify-center rounded-[10px] border border-primary-dark/45 bg-white/45 px-3 text-[13px] font-semibold text-primary-dark transition-colors duration-150 hover:bg-white sm:w-[174px] sm:text-sm">
				Book Appointment
			</a>
			<a href={directionsUrl} target="_blank" rel="noopener" class="col-span-2 inline-flex min-h-[36px] items-center gap-1.5 px-1 text-xs font-semibold text-primary-mid transition-colors duration-150 hover:text-primary-dark sm:w-full lg:mt-1">
				<svg aria-hidden="true" class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" /><circle cx="12" cy="10" r="3" /></svg>
				Get Directions
			</a>
		</div>
	</div>
</section>

<nav data-mobile-action-bar class="mobile-action-bar md:hidden" aria-label="Quick hospital actions">
	<a href="tel:9849287515" class="mobile-action-bar__secondary">Call Now</a>
	<a href="#contact" class="mobile-action-bar__primary">Book Appointment</a>
</nav>

<script>
	const hero = document.querySelector<HTMLElement>('#home');
	const mobileActionBar = document.querySelector<HTMLElement>('[data-mobile-action-bar]');

	if (hero && mobileActionBar) {
		const updateHeroActions = () => {
			const heroBottom = hero.offsetTop + hero.offsetHeight;
			const scrollTop = window.scrollY;
			const heroHasPassed = scrollTop > heroBottom;
			const showWhatsApp = scrollTop > hero.offsetTop + hero.offsetHeight * 0.62;

			mobileActionBar.classList.toggle('is-visible', heroHasPassed);
			document.body.classList.toggle('mobile-actions-visible', heroHasPassed);
			document.body.classList.toggle('hero-whatsapp-visible', showWhatsApp);
		};

		updateHeroActions();
		window.addEventListener('scroll', updateHeroActions, { passive: true });
		window.addEventListener('resize', updateHeroActions);
	}
</script>
