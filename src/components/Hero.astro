---
// Hero — mobile-first editorial composition.
// Copy + CTAs first; below them one shared visual canvas where the
// orthopaedic panel sits high/behind and the maternity arch overlaps
// in front, lower and to the right (not two equal card boxes).
// Assets: /images/hero-orthopaedic-visual.webp, /images/hero-maternity-visual.webp

const directionsUrl =
	'https://www.google.com/maps/dir/?api=1&destination=' +
	encodeURIComponent('Sri Vigneshwara Hospital, Vidya Nagar, Adilabad');
---

<section id="home" aria-label="Sri Vigneshwara Orthopaedic and Maternity Hospital, Adilabad">
	<div class="relative overflow-hidden bg-off-white">
		<!-- Flat tonal washes: ice left (ortho), cream right (maternity) -->
		<div
			aria-hidden="true"
			class="pointer-events-none absolute inset-y-0 left-0 w-1/2 bg-gradient-to-r from-ice to-transparent"
		>
		</div>
		<div
			aria-hidden="true"
			class="pointer-events-none absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l from-cream to-transparent"
		>
		</div>

		<div class="container-site relative py-10 sm:py-14 lg:px-12 lg:py-20">
			<div class="grid grid-cols-1 items-center gap-9 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16">
				<!-- Copy — first in DOM: headline + CTAs land above the visuals on mobile -->
				<div>
					<p class="label-caps text-primary-mid">
						Sri Vigneshwara Orthopaedic &amp; Maternity Hospital
					</p>

					<h1
						class="mt-3 max-w-[600px] font-heading text-[clamp(36px,9.5vw,44px)] leading-[1.05] font-bold tracking-[-0.02em] text-balance text-text-dark lg:text-[48px] lg:leading-[1.1]"
					>
						Trusted Orthopaedic &amp; Maternity Care in Adilabad
					</h1>

					<p class="mt-4 max-w-[520px] text-[15px] leading-relaxed text-text-muted sm:text-base lg:text-lg">
						Specialist care for mobility, pregnancy, women&rsquo;s health and children &mdash;
						delivered with compassion under one roof.
					</p>

					<div class="mt-6 flex flex-col gap-2.5 sm:flex-row sm:gap-3">
						<a
							href="tel:9849287515"
							class="inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-[10px] bg-cta px-6 py-3 text-[15px] font-semibold tracking-[0.02em] text-text-dark transition-colors duration-150 hover:bg-cta-hover sm:w-auto lg:px-8 lg:text-base"
						>
							<svg
								aria-hidden="true"
								class="size-4"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
							</svg>
							Call Hospital
						</a>
						<a
							href="#contact"
							class="inline-flex min-h-[48px] w-full items-center justify-center rounded-[10px] border border-primary-dark px-6 py-3 text-[15px] font-semibold tracking-[0.02em] text-primary-dark transition-colors duration-150 hover:bg-primary-dark hover:text-white sm:w-auto lg:px-8 lg:text-base"
						>
							Book Appointment
						</a>
					</div>

					<a
						href={directionsUrl}
						target="_blank"
						rel="noopener"
						class="mt-2 inline-flex min-h-[44px] items-center gap-1.5 text-sm font-semibold text-primary-mid transition-colors duration-150 hover:text-primary-dark"
					>
						<svg
							aria-hidden="true"
							class="size-4"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
							<circle cx="12" cy="10" r="3" />
						</svg>
						Get Directions
					</a>
				</div>

				<!-- Shared visual canvas: ortho behind/high-left, maternity in front/low-right -->
				<div
					aria-hidden="true"
					class="relative mx-auto h-[340px] w-full max-w-[380px] sm:h-[400px] sm:max-w-[440px] lg:h-[540px] lg:max-w-none"
				>
					<!-- Ortho panel (back layer) -->
					<div class="absolute top-0 left-0 w-[55%]">
						<div class="overflow-hidden rounded-[20px] bg-white shadow-md">
							<img
								src="/images/hero-orthopaedic-visual.webp"
								alt=""
								width="800"
								height="1067"
								fetchpriority="high"
								class="aspect-[3/4] h-auto w-full object-cover object-center"
							/>
						</div>
						<span
							class="absolute top-3 left-3 rounded-full bg-white/95 px-2.5 py-1 text-[10px] font-semibold whitespace-nowrap text-primary-dark shadow-sm sm:text-[11px]"
						>
							Orthopaedic Care
						</span>
					</div>

					<!-- Maternity arch (front layer, overlapping) -->
					<div class="absolute right-0 bottom-0 z-10 w-[52%]">
						<div
							class="overflow-hidden rounded-t-full rounded-b-[20px] bg-white shadow-lg ring-4 ring-off-white"
						>
							<img
								src="/images/hero-maternity-visual.webp"
								alt=""
								width="800"
								height="1067"
								fetchpriority="high"
								class="aspect-[3/4] h-auto w-full object-cover object-[center_65%]"
							/>
						</div>
						<span
							class="absolute bottom-3 left-1/2 -translate-x-1/2 rounded-full bg-white/95 px-2.5 py-1 text-[10px] font-semibold whitespace-nowrap text-maternity-deep shadow-sm sm:text-[11px]"
						>
							Maternity Care
						</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
