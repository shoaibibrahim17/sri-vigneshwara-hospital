---
// Conversion-focused hero: trust proof, streamlined actions and compact specialty bento.
const directionsUrl =
	'https://www.google.com/maps/dir/?api=1&destination=' +
	encodeURIComponent('Sri Vigneshwara Hospital, Vidya Nagar, Adilabad');
---

<section id="home" class="relative overflow-hidden bg-primary-dark" aria-labelledby="hero-heading">
	<div class="container-site relative pt-8 pb-16 sm:pt-12 sm:pb-20 lg:px-12 lg:py-20">
		<div class="grid items-center gap-7 lg:grid-cols-[0.98fr_1.02fr] lg:gap-14">
			<div class="hero-copy-enter">
				<p class="label-caps text-maternity">
					Sri Vigneshwara Orthopaedic &amp; Maternity Hospital
				</p>

				<h1 id="hero-heading" class="mt-3 max-w-[610px] font-heading text-[clamp(2.55rem,11vw,3rem)] leading-[0.99] font-medium tracking-[-0.035em] text-balance text-white lg:text-[clamp(3.5rem,5vw,4.65rem)]">
					Trusted Orthopaedic &amp; Maternity Care in Adilabad
				</h1>

				<div class="mt-3 flex max-w-[580px] flex-wrap items-center gap-x-2 gap-y-1 text-[11px] leading-relaxed font-medium text-white/65 sm:text-xs" aria-label="Hospital highlights">
					<span class="inline-flex items-center gap-1">
						<svg aria-hidden="true" class="size-3 text-cta" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z" /></svg>
						15+ Years Experience
					</span>
					<span aria-hidden="true" class="text-maternity/70">•</span>
					<span>24/7 Emergency Support</span>
					<span aria-hidden="true" class="text-maternity/70">•</span>
					<span>Vidya Nagar</span>
				</div>

				<p class="mt-4 max-w-[520px] text-[15px] leading-relaxed text-white/75 sm:text-base lg:text-lg">
					Specialist care for mobility, pregnancy, women&rsquo;s health and children &mdash; delivered with compassion under one roof.
				</p>

				<div class="mt-5 grid gap-2.5 sm:flex sm:flex-wrap sm:gap-3">
					<a href="#contact" class="inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-xl bg-cta px-6 py-3 text-[15px] font-semibold text-text-dark transition-colors duration-150 hover:bg-cta-hover sm:w-auto lg:px-8">
						<svg aria-hidden="true" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4M16 2v4M3 10h18" /><rect width="18" height="18" x="3" y="4" rx="2" /></svg>
						Book Appointment
					</a>
					<a href="tel:9849287515" class="inline-flex min-h-[48px] w-full items-center justify-center gap-2 rounded-xl border border-white/45 px-6 py-3 text-[15px] font-semibold text-white transition-colors duration-150 hover:bg-white hover:text-primary-dark sm:w-auto lg:px-8">
						<svg aria-hidden="true" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.36 1.79.7 2.63a2 2 0 0 1-.45 2.11L8.09 9.73a16 16 0 0 0 6.18 6.18l1.27-1.27a2 2 0 0 1 2.11-.45c.84.34 1.73.58 2.63.7A2 2 0 0 1 22 16.92z" /></svg>
						Call 98492 87515
					</a>
				</div>

				<a href={directionsUrl} target="_blank" rel="noopener" class="mt-3 hidden min-h-[44px] items-center gap-1.5 text-sm font-semibold text-white/75 transition-colors duration-150 hover:text-white lg:inline-flex">
					<svg aria-hidden="true" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" /><circle cx="12" cy="10" r="3" /></svg>
					Get Directions
				</a>
			</div>

			<div class="hero-visual-enter grid grid-cols-2 gap-3 lg:gap-4" aria-label="Our specialties">
				<a href="#orthopaedics" class="group relative min-h-[190px] overflow-hidden rounded-[42px_42px_16px_16px] border border-white/15 bg-ice sm:min-h-[260px] lg:min-h-[430px]">
					<img src="/images/hero-orthopaedic-visual.webp" alt="Orthopaedic knee and spine care illustration" width="800" height="1067" fetchpriority="high" class="absolute inset-0 h-full w-full object-cover object-[center_34%] transition-transform duration-300 ease-out group-hover:scale-[1.02]" />
					<span class="absolute inset-x-0 bottom-0 bg-white/95 px-3 py-3 text-center text-sm font-semibold text-primary-dark sm:text-base">Orthopaedics</span>
				</a>
				<a href="#maternity" class="group relative min-h-[190px] overflow-hidden rounded-[42px_42px_16px_16px] border border-white/15 bg-maternity-soft sm:min-h-[260px] lg:min-h-[430px]">
					<img src="/images/hero-maternity-visual.webp" alt="Mother and newborn maternity care illustration" width="800" height="1067" loading="eager" decoding="async" class="absolute inset-0 h-full w-full object-cover object-[center_38%] transition-transform duration-300 ease-out group-hover:scale-[1.02]" />
					<span class="absolute inset-x-0 bottom-0 bg-white/95 px-3 py-3 text-center text-sm font-semibold text-maternity-deep sm:text-base">Maternity</span>
				</a>
			</div>
		</div>
	</div>

	<svg aria-hidden="true" class="pointer-events-none absolute right-0 bottom-[-1px] h-8 w-full sm:h-12 lg:h-16" viewBox="0 0 1440 120" preserveAspectRatio="none">
		<path fill="#ffffff" d="M0,72 C220,112 418,16 676,48 C930,80 1102,132 1440,48 L1440,120 L0,120 Z" />
	</svg>
</section>

<nav data-mobile-action-bar class="mobile-action-bar md:hidden" aria-label="Quick hospital actions">
	<a href="tel:9849287515" class="mobile-action-bar__secondary">
		<svg aria-hidden="true" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.9.36 1.79.7 2.63a2 2 0 0 1-.45 2.11L8.09 9.73a16 16 0 0 0 6.18 6.18l1.27-1.27a2 2 0 0 1 2.11-.45c.84.34 1.73.58 2.63.7A2 2 0 0 1 22 16.92z" /></svg>
		Call Now
	</a>
	<a href="#contact" class="mobile-action-bar__primary">
		<svg aria-hidden="true" class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4M16 2v4M3 10h18" /><rect width="18" height="18" x="3" y="4" rx="2" /></svg>
		Book Appointment
	</a>
</nav>

<script>
	const hero = document.querySelector('#home');
	const mobileActionBar = document.querySelector('[data-mobile-action-bar]');

	if (hero && mobileActionBar) {
		const observer = new IntersectionObserver(([entry]) => {
			const heroHasPassed = !entry.isIntersecting && entry.boundingClientRect.bottom < 0;
			mobileActionBar.classList.toggle('is-visible', heroHasPassed);
			document.body.classList.toggle('mobile-actions-visible', heroHasPassed);
		}, { threshold: 0 });

		observer.observe(hero);
	}
</script>
