---
// Doctor profiles: one-column mobile stack, equal-height two-column desktop grid.
// IMPORTANT: replace initials only with hospital-approved photographs.
// OBGYN identity and qualifications remain intentionally unlisted until verified.
interface Doctor {
	name: string;
	title: string;
	experience?: string;
	status: string;
	timings: string;
	bio: string;
	accent: 'teal' | 'rose';
	initials: string;
}

const doctors: Doctor[] = [
	{
		name: 'Dr. Ravikanth Rao',
		title: 'Paediatrician',
		experience: '15+ Years Experience',
		status: 'Available Today',
		timings: 'Monday–Saturday · 9:30 AM–6:30 PM',
		bio: 'Cares for newborns, infants and children — from vaccinations to everyday illnesses.',
		accent: 'teal',
		initials: 'RR',
	},
	{
		name: 'Obstetrics & Gynaecology Specialist',
		title: 'Maternity & Women’s Health',
		status: 'Appointments Available Daily',
		timings: 'Monday–Sunday · 11:00 AM–5:00 PM',
		bio: 'Our OBGYN specialist supports pregnancy, delivery and women’s health at every stage.',
		accent: 'rose',
		initials: 'OB',
	},
];
---

<section id="doctors" class="bg-white" aria-labelledby="doctors-heading">
	<div class="section-pad">
		<div class="container-site mb-7 lg:mb-12 lg:px-12">
			<p class="label-caps text-text-muted">Our Doctors</p>
			<h2 id="doctors-heading" class="mt-2 text-text-dark">Meet Our Specialists</h2>
		</div>

		<ul class="container-site grid grid-cols-1 gap-4 md:max-w-[1000px] md:grid-cols-2 lg:gap-6 lg:px-12">
			{
				doctors.map((doctor) => (
					<li class="flex h-full flex-col rounded-[16px] border border-black/[0.06] bg-off-white p-5 transition-[box-shadow,transform] duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)] md:p-7">
						<div class="flex items-start gap-4">
							<span
								class:list={[
									'flex size-16 shrink-0 items-center justify-center rounded-[16px] font-heading text-xl font-semibold md:size-20 md:text-2xl',
									doctor.accent === 'teal'
										? 'bg-primary-dark/10 text-primary-dark'
										: 'bg-maternity/20 text-maternity-deep',
								]}
								aria-hidden="true"
							>
								{doctor.initials}
							</span>
							<div class="min-w-0">
								<h3 class="font-heading text-lg leading-tight font-semibold text-text-dark md:text-xl">
									{doctor.name}
								</h3>
								<p class="mt-1 text-sm font-medium text-text-muted">{doctor.title}</p>
								{doctor.experience && <p class="mt-0.5 text-[13px] text-text-muted">{doctor.experience}</p>}
							</div>
						</div>

						<div class="mt-4">
							<span
								class:list={[
									'inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold',
									doctor.accent === 'teal'
										? 'bg-[#E8F3EE] text-primary-dark'
										: 'bg-maternity-soft text-maternity-deep',
								]}
							>
								{doctor.accent === 'teal' ? (
									<span aria-hidden="true" class="size-2 rounded-full bg-success" />
								) : (
									<svg aria-hidden="true" class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 2v4M16 2v4M3 10h18" /><rect width="18" height="18" x="3" y="4" rx="2" /></svg>
								)}
								{doctor.status}
							</span>
							<p class="mt-2 flex items-center gap-1.5 text-[13px] text-text-muted [font-variant-numeric:tabular-nums]">
								<svg aria-hidden="true" class="size-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
								{doctor.timings}
							</p>
						</div>

						<p class="mt-4 text-sm leading-relaxed text-text-body">{doctor.bio}</p>

						<div class="mt-auto pt-5">
							<a
								href="#contact"
							aria-label={`Book appointment: ${doctor.title}`}
							class:list={[
								'inline-flex min-h-[44px] w-full items-center justify-center rounded-[10px] px-5 py-2.5 text-sm font-semibold transition-colors duration-150 sm:w-fit',
								doctor.accent === 'teal'
									? 'bg-primary-dark text-white hover:bg-primary-deep'
									: 'border border-maternity-deep text-maternity-deep hover:bg-maternity-soft',
							]}
						>
							Book Appointment
							</a>
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>
